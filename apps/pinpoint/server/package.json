{
  "name": "@pinpoint/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose -f ../compose.yaml up -d --wait",
    "db:down": "docker compose -f ../compose.yaml down",
    "db:init": "tsx scripts/db-init.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "flowcatalyst:sync": "tsx scripts/sync-flowcatalyst.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@flowcatalyst-apps/app-framework": "workspace:*",
    "@flowcatalyst/sdk": "github:flowcatalyst/typescript-sdk#semver:>=0.6.7",
    "@pinpoint/framework": "workspace:*",
    "@pinpoint/shared": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "drizzle-orm": "1.0.0-rc.1",
    "effect": "catalog:",
    "fastify": "^5.2.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@flowcatalyst-apps/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "1.0.0-rc.1",
    "tsx": "^4.19.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
