# Local dev env for @pinpoint/server. Copy to `.env` (gitignored) and fill the
# secrets. `pnpm dev` loads it via `--env-file=.env`. Prod injects these from
# the ECS task def / SSM instead — do NOT ship a .env to prod.

# ── Server ──────────────────────────────────────────────────────────────────
# 3100 (not 3000) to avoid colliding with a local fc-dev platform on :3000.
# Must match the vite proxy target (web/vite.config.ts → apiTarget default).
PORT=3100
HOST=0.0.0.0
LOG_LEVEL=debug
# Browser-facing base (the vite dev server). Used as the OIDC redirect base.
PINPOINT_PUBLIC_BASE_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Option 1 — the throwaway PostGIS container from `pnpm db:up` (port 5433):
DATABASE_URL=postgresql://pinpoint:pinpoint@localhost:5433/pinpoint
# Option 2 — fc-dev's embedded Postgres (port 15432) if it has PostGIS installed.
# Use a SEPARATE `pinpoint` db (not `flowcatalyst`) — `db:init` does an
# ALTER ROLE … SET search_path that you don't want to apply to the platform's db.
# Create it once:  psql ".../postgres" -c "CREATE DATABASE pinpoint;"
#   DATABASE_URL=postgresql://postgres:postgres@localhost:15432/pinpoint?sslmode=disable
PINPOINT_DB_SCHEMA=pinpoint
# Local uses `pnpm db:init` + `pnpm db:migrate`; leave startup auto-migrate off.
PINPOINT_DB_AUTO_MIGRATE=false

# ── Auth / OIDC ───────────────────────────────────────────────────────────────
# Option A — REAL login against the prod platform. The platform's "Pinpoint
# Login" client MUST also list http://localhost:5173/auth/callback as a
# redirect URI, or you'll get redirect_uri errors.
OIDC_ISSUER_URL=https://platform.inhanceapps.com
OIDC_CLIENT_ID=oac_6FE0WB4SAZR2P
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
OIDC_SCOPES=openid profile email
# Audience IS enforced, but defaults to the discovery issuer — which is what
# the FC platform stamps access tokens with (aud == iss == platform base URL;
# ID tokens get aud == client_id instead, so this is what rejects an ID token
# used as a bearer). Leave unset unless overriding for a non-standard IdP.
# OIDC_AUDIENCE=https://platform.inhanceapps.com
PINPOINT_AUTH_POST_LOGIN_REDIRECT=/
#
# Option B — SKIP OIDC for pure UI work: set this true and send the request
# header `x-user-id: prn_dev` (grants ALL permissions). Note the SPA's
# /auth/me check doesn't send that header, so this won't exercise the login
# flow — it's for API poking, not the browser login loop.
# PINPOINT_AUTH_DEV_FALLBACK=true

# ── Sessions — in-memory locally (lost on restart, single-process) ────────────
PINPOINT_SESSION_DRIVER=memory

# ── libpostal sidecar (from `pnpm db:up`) ─────────────────────────────────────
PINPOINT_LIBPOSTAL_URL=http://localhost:4400

# ── Geocoding — remote komoot by default; point at a local photon if running ──
# PINPOINT_GEOCODING_API_URL=https://photon.komoot.io

# ── LLM verifier — local Ollama + gemma (see runbook) ─────────────────────────
PINPOINT_LLM_PROVIDER=ollama
PINPOINT_OLLAMA_URL=http://localhost:11434
PINPOINT_LLM_MODEL=gemma4
# Bedrock instead (needs AWS creds in the shell):
#   PINPOINT_LLM_PROVIDER=bedrock
#   PINPOINT_BEDROCK_REGION=eu-central-1

# ── FlowCatalyst integration ──────────────────────────────────────────────────
FLOWCATALYST_CLIENT_ID=pinpoint
# FLOWCATALYST_SIGNING_SECRET=   # inbound webhook HMAC; optional locally
# Platform base URL + service-account creds for `pnpm flowcatalyst:sync`
# (registers roles / event types / subscriptions / scheduled jobs).
# FLOWCATALYST_URL=http://localhost:8080
# FLOWCATALYST_API_CLIENT_ID=oac_...
# FLOWCATALYST_API_CLIENT_SECRET=...
