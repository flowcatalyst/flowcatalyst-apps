# Copy to `.env` and tune. build-index.sh sources this automatically.

# ---------------------------------------------------------------------------
# Region — Geofabrik africa subregion slugs to combine into ONE Photon index.
# NOTE: Geofabrik uses the legacy name "swaziland", NOT "eswatini" — using
# "eswatini" 404s into an HTML page that breaks the merge. Lesotho + Swaziland
# are included explicitly; `osmium merge` dedupes any objects that also appear
# in a neighbouring extract (shared border ways/nodes).
# ---------------------------------------------------------------------------
COUNTRIES="south-africa namibia botswana zimbabwe mozambique lesotho swaziland"
GEOFABRIK_BASE=https://download.geofabrik.de/africa

# ---------------------------------------------------------------------------
# Photon — pin to a VERIFIED release: https://github.com/komoot/photon/releases
# (classic Elasticsearch flavour: photon-<version>.jar). The Photon version
# must understand the Nominatim schema version below — Photon 0.6.x ↔ Nominatim
# 4.x. If you bump one, check the other.
# ---------------------------------------------------------------------------
PHOTON_VERSION=0.6.2

# ---------------------------------------------------------------------------
# Throwaway Nominatim — mediagis/nominatim:4.4 ships PostgreSQL 14. This DB is
# destroyed (`down -v`) once the index is built; it never touches pinpoint's
# runtime Postgres. If you bump NOMINATIM_VERSION, set NOMINATIM_PGDATA to the
# image's PG major (e.g. /var/lib/postgresql/16/main for a PG16-based tag).
# ---------------------------------------------------------------------------
NOMINATIM_VERSION=4.4
NOMINATIM_PGDATA=/var/lib/postgresql/14/main
NOMINATIM_PASSWORD=nominatim
NOMINATIM_HTTP_PORT=8088

# Import style. 'address' is lean — enough for geocoding, far smaller/faster
# than 'full' (which adds POIs). Use 'full' only if you need POI search.
IMPORT_STYLE=address

# Postgres shared memory for the import. Bump to 2g–4g on a big build host.
NOMINATIM_SHM_SIZE=1g

# ---------------------------------------------------------------------------
# Output — a `-YYYYMMDD` stamp is appended to this prefix.
# ---------------------------------------------------------------------------
DIST_NAME=photon-data-southern-africa

# ---------------------------------------------------------------------------
# Runtime (compose.photon.yaml) — host port the served geocoder binds to.
# ---------------------------------------------------------------------------
PHOTON_HTTP_PORT=2322
